{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hydrasim reference samplesheet schema",
  "description": "Schema for the reference organisms CSV used by Hydrasim",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^\\S+$",
        "errorMessage": "Reference ID must be provided and cannot contain spaces"
      },
      "accession": {
        "anyOf": [
          { "const": "" },
          {
            "type": "string",
            "pattern": "^\\S+$"
          }
        ],
        "errorMessage": "Accession should be blank or a non-empty value without spaces"
      },
      "path": {
        "anyOf": [
          { "const": "" },
          {
            "type": "string",
            "format": "file-path",
            "pattern": "^\\S+$"
          }
        ],
        "errorMessage": "Path should be blank or a valid local FASTA file path without spaces"
      },
      "taxon_id": {
        "anyOf": [
          { "const": "" },
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "pattern": "^\\d+$"
          }
        ],
        "errorMessage": "taxon_id should be blank or an NCBI taxon ID (integer)"
      }
    },
    "required": ["id"],
    "additionalProperties": false,
    "oneOf": [
      {
        "required": ["accession"],
        "properties": {
          "accession": {
            "type": "string",
            "pattern": "^\\S+$"
          },
          "path": {
            "const": ""
          }
        }
      },
      {
        "required": ["path"],
        "properties": {
          "accession": {
            "const": ""
          },
          "path": {
            "type": "string",
            "format": "file-path",
            "pattern": "^\\S+$"
          }
        }
      }
    ],
    "errorMessage": {
      "oneOf": "Each reference row must provide exactly one of accession or path"
    }
  }
}
