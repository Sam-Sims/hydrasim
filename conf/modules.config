process {
    withName: NCBI_DATASETS_DOWNLOAD_GENOME {
        storeDir = { params.reference_dir }
    }
    withName: SRACHA_GET {
        storeDir = { params.dataset_dir }
        ext.args = {
            '--no-progress'
        }
    }
    withName: BADREAD_SIMULATE_WHOLE_REFERENCE {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/simulated" },
            mode: params.publish_dir_mode,
            enabled: { !params.tag_simulated_reads }
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x_simulated" }
        ext.args = {
            [
                "--length ${meta.badread_length}",
                "--identity ${params.badread_identity}",
                "--error_model ${params.badread_error_model}",
                "--qscore_model ${params.badread_qscore_model}",
                "--junk_reads ${params.badread_junk_reads}",
                "--random_reads ${params.badread_random_reads}",
                "--chimeras ${params.badread_chimeras}",
                "--glitches ${params.badread_glitches}"
            ].join(' ')
        }
    }
    withName: BADREAD_SIMULATE_SEGMENT {
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x_${meta.segment_id}" }
        ext.args = {
            [
                "--length ${meta.badread_length}",
                "--identity ${params.badread_identity}",
                "--error_model ${params.badread_error_model}",
                "--qscore_model ${params.badread_qscore_model}",
                "--junk_reads ${params.badread_junk_reads}",
                "--random_reads ${params.badread_random_reads}",
                "--chimeras ${params.badread_chimeras}",
                "--glitches ${params.badread_glitches}"
            ].join(' ')
        }
    }
    withName: WGSIM_WGSIM {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/simulated" },
            mode: params.publish_dir_mode,
            enabled: { !params.tag_simulated_reads }
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x_simulated" }
        ext.args = {
            [
                "-r ${params.wgsim_mutation_rate}",
                "-R ${params.wgsim_indel_fraction}"
            ].join(' ')
        }
    }
    withName: FASTQ_CONCAT_SEGMENTS {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/simulated" },
            mode: params.publish_dir_mode,
            enabled: { !params.tag_simulated_reads }
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x" }
    }
    withName: FASTQ_CONCAT_BACKGROUND {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/full" },
            mode: params.publish_dir_mode
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x" }
    }
    withName: SEQKIT_STATS {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/simulated" },
            mode: params.publish_dir_mode
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x_simulated" }
    }
    withName: FASTQ_TAG_READ_IDS {
        publishDir = [
            path: { "${params.outdir}/${meta.ref_id}/${meta.id}/simulated" },
            mode: params.publish_dir_mode
        ]
        ext.prefix = { "${meta.ref_id}_${meta.id}_${meta.coverage}x_simulated" }
    }
    withName: METADATA_RECORD {
        ext.prefix    = { "${meta.ref_id}_${meta.id}_${meta.coverage}x" }
        ext.reads_dir = { "${params.outdir}/${meta.ref_id}/${meta.id}/full" }
    }
    withName: SUMMARISE_SEQKIT {
        publishDir = [
            path: { params.outdir },
            mode: params.publish_dir_mode
        ]
    }
    withName: GENERATE_METADATA {
        publishDir = [
            path: { params.outdir },
            mode: params.publish_dir_mode
        ]
        ext.args = {
            [
                params.badread_per_segment ? '--badread-per-segment' : '--no-badread-per-segment',
                "--badread-length \"${params.badread_length}\"",
                "--badread-identity \"${params.badread_identity}\"",
                "--badread-error-model \"${params.badread_error_model}\"",
                "--badread-qscore-model \"${params.badread_qscore_model}\"",
                "--badread-junk-reads \"${params.badread_junk_reads}\"",
                "--badread-random-reads \"${params.badread_random_reads}\"",
                "--badread-chimeras \"${params.badread_chimeras}\"",
                "--badread-glitches \"${params.badread_glitches}\"",
                "--badread-low-coverage-length \"${params.badread_low_coverage_length}\"",
                params.downsample_background ? '--downsample-background' : '--no-downsample-background',
                "--dataset-coverage \"${params.dataset_coverage}\"",
                "--wgsim-length-read1 \"${params.wgsim_length_read1}\"",
                "--wgsim-length-read2 \"${params.wgsim_length_read2}\"",
                "--wgsim-mutation-rate \"${params.wgsim_mutation_rate}\"",
                "--wgsim-indel-fraction \"${params.wgsim_indel_fraction}\"",
                "--study-id \"${params.metadata_study_id}\"",
                "--sample-source \"${params.metadata_sample_source}\"",
                "--sample-type \"${params.metadata_sample_type}\"",
                "--governance-status \"${params.metadata_governance_status}\"",
                "--input-type \"${params.metadata_input_type}\"",
                "--spike-in \"${params.metadata_spike_in}\"",
                params.metadata_received_date ? "--received-date \"${params.metadata_received_date}\"" : ''
            ].minus('').join(' ')
        }
    }
}
