params {
    // Input CSVs
    reference_csv = null
    dataset_csv   = null

    // Outputs
    outdir           = 'output'
    publish_dir_mode = 'copy'
    tracedir         = "${params.outdir}/pipeline_info"

    // Store dirs
    reference_dir = 'store/references'
    dataset_dir   = 'store/datasets'


    // Simulation opts
    coverages             = [0.1, 1, 10, 100]
    // disables/enables rasusa initial downsampling
    downsample_background = true
    // if enabled - how many bases to downsample to (ignore if downsample_background = false)
    dataset_coverage      = '10k'
    // if enabled append tags (e.g. _badread/_wgsim) to simulated read IDs for later identification
    tag_simulated_reads = false

    // Badread parameters (set to badread defaults)
    badread_length               = '15000,13000'
    badread_identity             = '95,99,2.5'
    badread_error_model          = 'nanopore2023'
    badread_qscore_model         = 'nanopore2023'
    badread_junk_reads           = 1
    badread_random_reads         = 1
    badread_chimeras             = 1
    badread_glitches             = '10000,25,25'
    // Seed for badread (if wanting deterministic output)
    badread_seed                 = null
    // Run badread on every record in the input fasta (useful to force outputs for segmented genomes at low coverage levels)
    badread_per_segment          = false
    // The cutoff to apply badread_low_coverage_length
    badread_low_coverage_cutoff  = 0
    // Different badread length settings to apply to any coverages below badread_low_coverage_cutoff
    badread_low_coverage_length  = '400,100'

    // Wgsim parameters (set to wgsim defaults)
    wgsim_length_read1   = '150'
    wgsim_length_read2   = '150'
    wgsim_mutation_rate  = '0.001'
    wgsim_indel_fraction = '0.15'

    // Metadata generation (opt-in with --generate_metadata)
    generate_metadata          = false
    metadata_study_id          = 'hydrasim'
    metadata_sample_source     = 'other'
    metadata_sample_type       = 'other'
    metadata_governance_status = 'no_consent_for_research'
    metadata_input_type        = 'validation_material'
    metadata_spike_in          = 'none'
    metadata_received_date     = null
}
